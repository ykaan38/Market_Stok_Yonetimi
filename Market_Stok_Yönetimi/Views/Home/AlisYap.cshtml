@model Market_Stok_Yönetimi.Model.Alis
@{
    ViewBag.Title = "Stok Girişi";
}

@{
    ViewBag.Title = "AlisYap";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="form-container">
    <h2>Stok Girişi</h2>

    @using (Html.BeginForm("AlisYap", "Home", FormMethod.Post))
    {


        <div class="form-group">
            <label>Ürün</label>
            @Html.DropDownList("urunID", (SelectList)ViewBag.Urunler, "Ürün Seçin", new { @class = "form-control" })
        </div>
        
        <div class="form-group">
            <label>Miktar</label>
            <div class="input-group">
                <span class="input-group-prepend">Adet</span>
                <input type="number" name="miktar" class="form-control" required min="1" />
            </div>
        </div>

        <div class="form-group">
            <label>Birim Fiyat (Alış)</label>
            <div class="input-group">
                <span class="input-group-prepend">₺</span>
                <input type="text" name="birimFiyat" step="0.01" class="form-control" value="0" required min="0.01" />
            </div>
        </div>

        <button type="submit" class="btn-submit">
            Stok Girişi Yap
        </button>
    }
</div>




<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
<style>

    :root {
        --form-primary: #ba7c00;
        --form-secondary: #ba7c00;
        --form-bg: #f5f9ff;
        --form-border: #ba7c00;
        --form-text: #ba7c00;
        --form-shadow: #ba7c00;
    }

    body {
        background-color: #1E1E1E;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        padding: 15px;
        color: white;
    }

    .form-container {
        max-width: 600px;
        margin: 30px auto;
        padding: 30px;
        background-color: #2D2D2D;
        border-radius: 12px;
        box-shadow: 0 5px 15px #ba7c00;
        border: 1px solid #ba7c00;
    }

        .form-container h2 {
            color: #ba7c00;
            margin-top: 0;
            margin-bottom: 25px;
            padding-bottom: 10px;
            border-bottom: 2px solid #ba7c00;
            text-align: center;
        }

    .form-group {
        margin-bottom: 20px;
    }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 500;
            color: #ba7c00;
        }

    .form-control {
        width: 100%;
        padding: 12px 15px;
        border: 1px solid #ba7c00;
        border-radius: 6px;
        font-size: 1rem;
        transition: all 0.3s;
        background-color: #f5f9ff;
    }

        .form-control:focus {
            outline: none;
            border-color: #ba7c00;
            box-shadow: 0 0 0 3px rgba(0, 0, 0, 0.2);
            background-color: white;
        }

    select.form-control {
        appearance: none;
        background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%232196F3' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
        background-repeat: no-repeat;
        background-position: right 10px center;
        background-size: 15px;
    }

    .btn-submit {
        background-color: #ba7c00;
        color: white;
        border: none;
        padding: 12px 25px;
        font-size: 1rem;
        font-weight: 500;
        border-radius: 6px;
        cursor: pointer;
        transition: all 0.3s;
        width: 100%;
        margin-top: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

        .btn-submit:hover {
            background-color: #1976D2;
            transform: translateY(-2px);
            box-shadow: 0 4px 8px #ba7c00;
        }

    .form-footer {
        margin-top: 25px;
        text-align: center;
        color: #666;
        font-size: 0.9rem;
    }

    .input-group {
        display: flex;
        align-items: center;
    }

    .input-group-prepend {
        padding: 12px 15px;
        background-color: #ba7c00;
        border: 1px solid var(--form-border);
        border-right: none;
        border-radius: 6px 0 0 6px;
        color: white;
        font-weight: 500;
    }

    .input-group input {
        border-radius: 0 6px 6px 0 !important;
    }

    @@media (max-width: 768px) {
        .form-container {
            padding: 20px;
            margin: 20px;
        }
    }
</style>
