@model Market_Stok_Yönetimi.Model.Urun
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<div class="edit-container">
    <h2>Ürün Düzenle</h2>

    @using (Html.BeginForm())
    {
        @Html.HiddenFor(model => model.UrunID)

        <div class="form-group">
            @Html.LabelFor(model => model.UrunAdi)
            @Html.TextBoxFor(model => model.UrunAdi, new { placeholder = "Ürün adını giriniz" })
            @Html.ValidationMessageFor(model => model.UrunAdi)
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.Barkod)
            @Html.TextBoxFor(model => model.Barkod, new { placeholder = "Barkod numarası" })
            @Html.ValidationMessageFor(model => model.Barkod)
        </div>

        <div class="form-group currency-input">
            @Html.LabelFor(model => model.BirimFiyat)
            <span class="currency-symbol">₺</span>
            @Html.TextBoxFor(model => model.BirimFiyat, new { type = "text", step = "1.00", min = "0" })
            @Html.ValidationMessageFor(model => model.BirimFiyat)
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.StokMiktari)
            @Html.TextBoxFor(model => model.StokMiktari, new { type = "number", min = "0" })
            @Html.ValidationMessageFor(model => model.StokMiktari)
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.KritikSeviye)
            @Html.TextBoxFor(model => model.KritikSeviye, new { type = "number", min = "0" })
            @Html.ValidationMessageFor(model => model.KritikSeviye)
            <span class="input-hint">Stok uyarı vermesi için minimum seviye</span>
        </div>

        <button type="submit" class="btn-submit">
            GÜNCELLE
        </button>
    }
</div>




<style>
    :root {
        --primary-color: #ba7c00;
        --secondary-color: #ba7c00;
        --light-color: #E8F5E9;
        --text-color: #333;
        --border-color: #C8E6C9;
        --focus-color: #81C784;
        --error-color: #f44336;
    }

    body {
        background-color: #1E1E1E;
    }

    .edit-container {
        max-width: 600px;
        margin: 20px auto;
        padding: 25px;
        background: #2D2D2D;
        color: white;
        border-radius: 12px;
        box-shadow: 0 5px 15px #ba7c00;
        border: 1px solid #ba7c00;
    }

    h2 {
        color: var(--secondary-color);
        text-align: center;
        margin-bottom: 25px;
        padding-bottom: 10px;
        border-bottom: 2px solid var(--light-color);
    }

    .form-group {
        margin-bottom: 20px;
    }

    label {
        display: block;
        margin-bottom: 8px;
        font-weight: 500;
        color: var(--secondary-color);
    }

    input[type="text"],
    input[type="number"] {
        width: 100%;
        padding: 10px 15px;
        border: 1px solid var(--border-color);
        border-radius: 4px;
        font-size: 16px;
        transition: all 0.3s;
        box-sizing: border-box;
    }

        input[type="text"]:focus,
        input[type="number"]:focus {
            border-color: var(--primary-color);
            outline: none;
            box-shadow: 0 0 0 3px rgba(76, 175, 80, 0.2);
        }

    .btn-submit {
        background-color: var(--primary-color);
        color: white;
        border: none;
        padding: 12px 20px;
        font-size: 16px;
        border-radius: 4px;
        cursor: pointer;
        width: 100%;
        transition: all 0.3s;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

        .btn-submit:hover {
            background-color: var(--secondary-color);
            transform: translateY(-2px);
        }

    .field-validation-error {
        color: var(--error-color);
        font-size: 14px;
        margin-top: 5px;
        display: block;
    }

    .input-hint {
        font-size: 13px;
        color: #666;
        margin-top: 5px;
        display: block;
    }

    .currency-input {
        position: relative;
    }

    .currency-symbol {
        position: absolute;
        left: 10px;
        top: 50%;
        transform: translateY(-50%);
        color: #777;
    }

    .currency-input input {
        padding-left: 30px !important;
    }

    @@media (max-width: 768px) {
        .edit-container {
            padding: 15px;
            margin: 15px;
        }

        h2 {
            font-size: 1.5rem;
        }

        input[type="text"],
        input[type="number"] {
            padding: 8px 12px;
        }
    }
</style>



