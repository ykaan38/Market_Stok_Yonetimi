@model Market_Stok_Yönetimi.Model.Urun
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="form-container">
    <h2>Ürün Ekle</h2>

    @using (Html.BeginForm())
    {
        <div class="form-group">
            @Html.LabelFor(model => model.UrunAdi)
            @Html.TextBoxFor(model => model.UrunAdi, new { placeholder = "Ürün Adı" })
            @Html.ValidationMessageFor(model => model.UrunAdi, "", new { @class = "field-validation" })
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.Barkod)
            @Html.TextBoxFor(model => model.Barkod, new { placeholder = "Barkod numarası" })
            @Html.ValidationMessageFor(model => model.Barkod, "", new { @class = "field-validation" })
        </div>


        <div class="form-group">
            @Html.LabelFor(model => model.BirimFiyat)
            <div class="input-with-icon">
                <span>₺</span>
                @Html.TextBoxFor(model => model.BirimFiyat, new { @class = "form-control", type = "text", step = "0.01", placeholder = "Birim Fiyat" })
            </div>
            @Html.ValidationMessageFor(model => model.BirimFiyat, "", new { @class = "field-validation" })
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.StokMiktari)
            @Html.TextBoxFor(model => model.StokMiktari, new { type = "number", min = "0" })
            @Html.ValidationMessageFor(model => model.StokMiktari, "", new { @class = "field-validation" })
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.KritikSeviye)
            @Html.TextBoxFor(model => model.KritikSeviye, new { type = "number", min = "0" })
            @Html.ValidationMessageFor(model => model.KritikSeviye, "", new { @class = "field-validation" })
            <span class="input-hint">Stok uyarı seviyesi</span>
        </div>

        <button type="submit" class="btn-submit">
            KAYDET
        </button>
    }
</div>





<style>
    :root {
        --primary-color: #ba7c00;
        --secondary-color: #ba7c00;
        --light-color: #E8F5E9;
        --border-color: #C8E6C9;
        --focus-color: #81C784;
    }

    body {
        background-color: #1E1E1E;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        padding: 15px;
        color: white;
    }

    .form-container {
        max-width: 100%;
        margin: 0 auto;
        padding: 20px;
        background: #2D2D2D;
        border-radius: 12px;
        box-shadow: 0 5px 15px #ba7c00;
        border: 1px solid #ba7c00;
    }

    h2 {
        color: var(--secondary-color);
        text-align: center;
        margin-bottom: 20px;
        font-weight: 600;
        font-size: 1.5rem;
    }

    .form-group {
        margin-bottom: 15px;
    }

    label {
        display: block;
        margin-bottom: 6px;
        font-weight: 500;
        color: var(--secondary-color);
        font-size: 0.9rem;
    }

    input[type="text"],
    input[type="number"] {
        width: 100%;
        padding: 8px 12px;
        border: 1px solid var(--border-color);
        border-radius: 4px;
        font-size: 0.9rem;
        box-sizing: border-box;
    }

    .input-with-icon {
        position: relative;
    }

        .input-with-icon span {
            position: absolute;
            left: 10px;
            top: 50%;
            transform: translateY(-50%);
            color: #777;
        }

        .input-with-icon input {
            padding-left: 25px !important;
        }

    .btn-submit {
        background-color: var(--primary-color);
        color: white;
        border: none;
        padding: 10px;
        font-size: 0.9rem;
        border-radius: 4px;
        cursor: pointer;
        width: 100%;
        margin-top: 15px;
    }

    .field-validation {
        color: #D32F2F;
        font-size: 0.8rem;
        margin-top: 4px;
        display: block;
    }

    .input-hint {
        font-size: 0.75rem;
        color: #666;
        margin-top: 4px;
    }

    @@media (min-width: 768px) {
        .form-container {
            max-width: 600px;
            padding: 25px;
        }

        h2 {
            font-size: 1.8rem;
            margin-bottom: 25px;
        }

        input[type="text"],
        input[type="number"] {
            padding: 10px 15px;
            font-size: 1rem;
        }

        .btn-submit {
            padding: 12px;
            font-size: 1rem;
        }
    }
</style>

